# .env.example — 教学智能体项目完整环境变量
# 复制为 .env 后修改

# ========== 项目 ==========
APP_NAME=edu-agent
APP_ENV=development        # development | production
DEBUG=true

# ========== 服务端口（可自定义避免冲突） ==========
NGINX_PORT=80
BACKEND_PORT=8000
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# ========== 数据库 ==========
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=edu_agent
POSTGRES_USER=edu_agent
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql+asyncpg://edu_agent:change-me@postgres:5432/edu_agent

# ========== Redis ==========
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://redis:6379/0

# ========== Celery ==========
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ========== ChromaDB ==========
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# ========== 对象存储 (MinIO) ==========
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=edu-agent-files
MINIO_SECURE=false

# ========== LLM 配置 ==========
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL_NAME=deepseek-chat
LLM_API_KEY=sk-your-api-key-here
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2048

# ========== 护栏 LLM（可复用主 LLM） ==========
GUARD_LLM_BASE_URL=https://api.deepseek.com/v1
GUARD_LLM_MODEL_NAME=deepseek-chat
GUARD_LLM_API_KEY=sk-your-api-key-here

# ========== 查询改写 LLM（可复用主 LLM） ==========
REWRITE_LLM_BASE_URL=https://api.deepseek.com/v1
REWRITE_LLM_MODEL_NAME=deepseek-chat
REWRITE_LLM_API_KEY=sk-your-api-key-here

# ========== Embedding 模型（本地 BGE-M3） ==========
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIMENSION=1024
EMBEDDING_DEVICE=cpu
EMBEDDING_LOCAL_ONLY=true

# ========== Reranker 模型（本地 BGE-Reranker） ==========
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_DEVICE=cpu
RERANKER_LOCAL_ONLY=true

# ========== JWT ==========
JWT_SECRET_KEY=change-me-jwt-secret-min-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ========== 文件上传 ==========
MAX_UPLOAD_SIZE_MB=50
ALLOWED_EXTENSIONS=pdf,docx,pptx,md,txt,xlsx

# ========== CORS ==========
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost

# ========== 安全 ==========
GUARDRAIL_INPUT_ENABLED=true
GUARDRAIL_OUTPUT_ENABLED=true
